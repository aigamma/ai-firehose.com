node_modules
dist
.env
.env.local
*.local
.DS_Store
.netlify

# Leftovers from yt-dlp's python3 runtime; the worker itself is pure Node (no Python source in the repo)
worker/.venv
__pycache__/
*.pyc

# Local-only scratch and downloaded media
.tmp/
.tmp_*
# Glossary image curation staging: subagents write per-category candidate rows here,
# and `glossary_images.mjs finalize` merges them into content/glossary/images.json (the
# committed source of truth) then deletes this dir. The staging files are transient.
content/glossary/_img_stage/
# Vite's local cache, and a scratch dir used for headless-screenshot verification.
.vite/
# The .cache holds regenerable caches (classify, definitions, axis_vectors) AND the
# accumulating retention-pruned corpus, items.json. The corpus is durable state, not a
# cache: it must persist across runs or the rolling quarter never accumulates and the
# Pinecone reconcile prunes the index down to the latest feed snapshot. So commit
# items.json and ignore the rest of the directory.
worker/.cache/*
!worker/.cache/items.json
!worker/.cache/vector_manifest.json
!worker/.cache/shorts.json
*.mp3
*.m4a
*.wav
