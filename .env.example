# Copy to .env.local for the worker. Never commit real keys.
# At build time the worker reads keys from sibling repo .env files
# (see docs/OPERATIONS.md), then they are set as Fly.io secrets and
# Netlify environment variables. This file lists names only.

# Pinecone (vector store)
PINECONE_API_KEY=
PINECONE_INDEX=ai-firehose
PINECONE_HOST=

# Voyage AI (embeddings voyage-3 + rerank-2)
VOYAGE_API_KEY=

# Anthropic (classification, cluster naming, glossary definitions)
ANTHROPIC_API_KEY=

# OpenAI (optional dual-check on classification, optional Whisper API)
OPENAI_API_KEY=

# Optional paid fallback scraper, only if RSS / yt-dlp is blocked at scale
APIFY_TOKEN=
